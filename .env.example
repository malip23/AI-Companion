# Vapi webhook secret — found in Vapi dashboard under Webhooks
VAPI_WEBHOOK_SECRET=

# Vapi public key — found in Vapi dashboard under API Keys
EXPO_PUBLIC_VAPI_KEY=

# Vapi assistant ID — found in Vapi dashboard under Assistants
EXPO_PUBLIC_ASSISTANT_ID=

# Local server URL — use your machine's local IP, e.g. http://192.168.1.x:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
